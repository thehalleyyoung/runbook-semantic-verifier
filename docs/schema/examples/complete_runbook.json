{
  "name": "Complete documented DSL fixture",
  "description": "A strict JSON fixture exercising every supported top-level runbook field.",
  "metadata": {
    "labels": {
      "expected_safe": true,
      "expected_violation_properties": [],
      "expected_prose_rules": []
    },
    "waivers": [
      {
        "id": "documented-effect-waiver-example",
        "owner": "sre-platform",
        "expiry": "2099-12-31",
        "scope": "step:flush-api-cache",
        "rationale": "Demonstrates schema for a visible waiver without suppressing a live benchmark finding.",
        "invariant": "effect_annotation_required",
        "benchmark_visibility": "visible"
      }
    ],
    "owner": "sre-platform",
    "source": "synthetic schema example"
  },
  "allow_reordering": true,
  "max_depth": 9,
  "safety": {
    "max_alert_suppression_minutes": 30
  },
  "system": {
    "clock_minute": 0,
    "regions": {
      "us-east": {
        "healthy": true
      },
      "us-west": {
        "healthy": true
      }
    },
    "services": {
      "api": {
        "deployment": "v2",
        "min_available": 1,
        "replicas": [
          {
            "id": "api-east-0",
            "region": "us-east",
            "healthy": true,
            "drained": false
          },
          {
            "id": "api-west-0",
            "region": "us-west",
            "healthy": true,
            "drained": false
          }
        ]
      }
    },
    "databases": {
      "orders": {
        "primary_region": "us-east",
        "healthy_regions": ["us-east", "us-west"],
        "quorum_confirmed": false,
        "migration_in_progress": false,
        "migration_compatible": true
      }
    },
    "queues": {
      "orders-events": {
        "depth": 0,
        "consumers": 2,
        "paused": false
      }
    },
    "caches": {
      "api-cache": {
        "service": "api",
        "entries": 1000,
        "warmup_entries": 800,
        "capacity_entries": 1200,
        "warm": true,
        "write_frozen": false
      }
    },
    "alerts": {
      "api-error-rate": {
        "active": true,
        "suppressed_until_minute": null
      }
    },
    "feature_flags": {
      "brownout": {
        "enabled": false
      }
    },
    "deployments": {
      "api": {
        "service": "api",
        "current": "v2",
        "previous": "v1"
      }
    },
    "traffic_routes": {
      "api-public": {
        "service": "api",
        "weights": {
          "us-east": 100,
          "us-west": 0
        },
        "drained_regions": []
      }
    },
    "dns_records": {
      "api.example.com": {
        "service": "api",
        "region": "us-east",
        "ttl_minutes": 5,
        "last_changed_minute": 0,
        "previous_region": null,
        "health_check_converged_regions": ["us-east", "us-west"],
        "allow_split_brain": true
      }
    },
    "credentials": {
      "api-key": {
        "owner": "sre-platform",
        "revoked": false,
        "rotation_due_minute": 60
      }
    }
  },
  "steps": [
    {
      "id": "confirm-orders-quorum",
      "action": "confirm_quorum",
      "params": {
        "database": "orders"
      },
      "requires": [
        {
          "kind": "region_healthy",
          "region": "us-west"
        }
      ],
      "effects": [
        {
          "kind": "database_quorum_confirmed",
          "database": "orders"
        }
      ]
    },
    {
      "id": "failover-orders-west",
      "action": "failover_database",
      "params": {
        "database": "orders",
        "target_region": "us-west",
        "data_loss_risk": false
      },
      "after": ["confirm-orders-quorum"],
      "requires": [
        {
          "kind": "database_quorum_confirmed",
          "database": "orders"
        }
      ],
      "effects": [
        {
          "kind": "database_primary_region",
          "database": "orders",
          "region": "us-west"
        }
      ]
    },
    {
      "id": "shift-api-traffic-west",
      "action": "failover_traffic",
      "params": {
        "route": "api-public",
        "target_region": "us-west"
      },
      "after": ["failover-orders-west"],
      "requires": [
        {
          "kind": "region_healthy",
          "region": "us-west"
        }
      ],
      "effects": [
        {
          "kind": "traffic_weight_is",
          "route": "api-public",
          "region": "us-west",
          "percent": 100
        }
      ]
    },
    {
      "id": "wait-for-dns",
      "action": "wait",
      "params": {
        "minutes": 5
      },
      "after": ["shift-api-traffic-west"]
    },
    {
      "id": "resume-orders-events",
      "action": "resume_queue",
      "params": {
        "queue": "orders-events"
      },
      "after": ["wait-for-dns"],
      "effects": [
        {
          "kind": "queue_resumed",
          "queue": "orders-events"
        }
      ]
    },
    {
      "id": "freeze-api-cache",
      "action": "freeze_cache_writes",
      "params": {
        "cache": "api-cache"
      },
      "after": ["resume-orders-events"],
      "effects": [
        {
          "kind": "cache_writes_frozen",
          "cache": "api-cache"
        }
      ]
    },
    {
      "id": "flush-api-cache",
      "action": "flush_cache",
      "params": {
        "cache": "api-cache"
      },
      "after": ["freeze-api-cache"],
      "requires": [
        {
          "kind": "cache_writes_frozen",
          "cache": "api-cache"
        }
      ],
      "effect_annotations": {
        "effect_types": ["deletion"],
        "idempotency": "unknown",
        "reversibility": "unknown",
        "retry_safety": "unknown",
        "blast_radius": "api cache entries",
        "expected_user_impact": "possible cold-cache latency until warmup completes",
        "reviewed_by": ["sre-platform"]
      }
    },
    {
      "id": "warm-api-cache",
      "action": "warm_cache",
      "params": {
        "cache": "api-cache",
        "entries": 1000
      },
      "after": ["flush-api-cache"],
      "requires": [
        {
          "kind": "cache_capacity_at_least",
          "cache": "api-cache",
          "entries": 1000
        }
      ],
      "effects": [
        {
          "kind": "cache_warm",
          "cache": "api-cache"
        },
        {
          "kind": "cache_no_stale_read_risk",
          "cache": "api-cache"
        }
      ]
    },
    {
      "id": "resume-api-cache-writes",
      "action": "resume_cache_writes",
      "params": {
        "cache": "api-cache"
      },
      "after": ["warm-api-cache"],
      "requires": [
        {
          "kind": "cache_warm",
          "cache": "api-cache"
        }
      ]
    }
  ]
}
